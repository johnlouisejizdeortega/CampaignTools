APP_NAME="Google Ads Team Dashboard"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack

# Uses a local SQLite file so no MySQL server is required.
DB_CONNECTION=sqlite

CACHE_STORE=file
SESSION_DRIVER=file
QUEUE_CONNECTION=sync

# Set a strong shared password to require login before anyone can use the
# dashboard. Leave empty to disable the login gate (local dev only).
TEAM_ACCESS_PASSWORD=

# Google Ads API credentials. Set these to enable the live features (reports,
# pause, recommendations, account analysis) without a google_ads_php.ini file —
# ideal for Laravel Cloud. If left empty, the app falls back to google_ads_php.ini.
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
# Required only for manager (MCC) accounts; customer ID without dashes.
GOOGLE_ADS_LOGIN_CUSTOMER_ID=
