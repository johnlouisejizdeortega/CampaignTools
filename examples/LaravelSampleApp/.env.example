APP_NAME="Google Ads Team Dashboard"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack

# Uses a local SQLite file so no MySQL server is required.
DB_CONNECTION=sqlite

CACHE_STORE=file
SESSION_DRIVER=file
QUEUE_CONNECTION=sync

# Set a strong shared password to require login before anyone can use the
# dashboard. Leave empty to disable the login gate (local dev only).
TEAM_ACCESS_PASSWORD=
